{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dtl-spec.io/schemas/v1/patterns/coordinator.schema.json",
  "title": "DTL Coordinator Pattern",
  "type": "object",
  "required": ["payloadType", "source", "name", "data"],
  "properties": {
    "payloadType": { "const": "EVENT" },
    "source":      { "type": "string" },
    "name":        { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
    "data": {
      "type": "object",
      "required": ["operation","status","executionTimeMs","instanceId","traceId"],
      "properties": {
        "operation":       { "type": "string" },
        "status":          { "type": "string" },
        "executionTimeMs": { "type": "integer", "minimum": 0 },
        "instanceId":      { "type": "string" },
        "traceId":         { "type": "string", "pattern": "^[a-f0-9]{32}$" }
      }
    }
  }
}